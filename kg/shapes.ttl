@prefix bio: <https://example.org/bio-kg/> .
@prefix dwc: <http://rs.tdwg.org/dwc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dwc:Occurrence a sh:NodeShape ;
    rdfs:comment "A single observation of an organism at a place and time." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class prov:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path prov:wasAttributedTo ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path bio:iconicGroup ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:maxInclusive 180 ;
            sh:minCount 1 ;
            sh:minInclusive -180 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dwc:decimalLongitude ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:maxInclusive 90 ;
            sh:minCount 1 ;
            sh:minInclusive -90 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dwc:decimalLatitude ],
        [ sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path bio:id ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dwc:eventDate ],
        [ sh:class dwc:Taxon ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path bio:observedTaxon ] ;
    sh:targetClass dwc:Occurrence .

dwc:Taxon a sh:NodeShape ;
    rdfs:comment "A taxonomic group (species, genus, family, etc.)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dwc:scientificName ],
        [ sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path bio:id ],
        [ sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path rdfs:seeAlso ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path rdfs:label ] ;
    sh:targetClass dwc:Taxon .

prov:Agent a sh:NodeShape ;
    rdfs:comment "A person who recorded an observation. The IRI itself is the observer's iNaturalist user URL (or ORCID URL when available); no further data is stored on the agent node beyond the type declaration." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path bio:id ] ;
    sh:targetClass prov:Agent .


